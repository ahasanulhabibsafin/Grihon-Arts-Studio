rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Path Variable Hardening helper
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == 'safinbakshi013@gmail.com' && 
             request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints
    function isValidGraphic(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.category is string && data.category.size() <= 64 &&
             data.previewUrl is string && data.previewUrl.size() <= 500 &&
             data.downloadUrl is string && data.downloadUrl.size() <= 500 &&
             data.price is number;
    }

    match /graphics/{graphicId} {
      allow list, get: if true; // Public marketplace
      
      allow create: if isAdmin() && 
                      isValidId(graphicId) &&
                      isValidGraphic(incoming()) &&
                      incoming().createdAt == request.time &&
                      incoming().keys().hasAll(['title', 'description', 'category', 'previewUrl', 'downloadUrl', 'price', 'createdAt']) &&
                      incoming().keys().size() == 7;

      allow update: if isAdmin() &&
                      isValidGraphic(incoming()) &&
                      incoming().createdAt == existing().createdAt && // Immutable
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'previewUrl', 'downloadUrl', 'price']);

      allow delete: if isAdmin();
    }
  }
}
